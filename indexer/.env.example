# RPC endpoint the indexer reads from.
RPC_URL=https://testnet.asentum.com

# Where the SQLite file lives. Create the directory first.
DB_PATH=./data/index.db

# HTTP API port (internal-only; bind 127.0.0.1 in production).
PORT=3002
HOST=127.0.0.1

# Indexer behavior.
POLL_MS=3000                 # how often to check for new blocks once caught up
BATCH_SIZE=25                # blocks per JSON-RPC batch during backfill
START_FROM=0                 # backfill from this block on first run (or 'latest' to skip backfill)
