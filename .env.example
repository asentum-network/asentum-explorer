# Public RPC endpoint the explorer hits for chain data.
# Must be reachable from both the browser (CORS-friendly) and the server.
NEXT_PUBLIC_RPC_URL=https://testnet.asentum.com

# Optional: chain ID for display + sanity checks. Asentum testnet = 1337.
NEXT_PUBLIC_CHAIN_ID=1337

# Optional: chain display name (e.g., "Testnet", "Mainnet").
NEXT_PUBLIC_CHAIN_NAME=Testnet

# Internal URL for the asentum-indexer service (server-side only).
# The Next.js /api/indexer/* proxy forwards requests here. Bind the indexer
# to 127.0.0.1 in production so only Next.js can reach it.
INDEXER_URL=http://127.0.0.1:3002
